PORT=3000
PUBLIC_BASE_URL=https://contracts.edgewaterhomestores.com
SESSION_SECRET=change-this-to-a-long-random-value
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
STAFF_MAX_ACTIVE_SESSIONS=3

# Fresh installs do not create demo/store users unless this is explicitly true.
# Existing data/settings/users.json users are preserved.
PORTAL_SEED_STAFF=false

# Optional. If blank, the portal creates and watches ./data/estimates.
# Point this at the CabQuotes2/EWCS_Q2E estimates folder when both apps
# should share saved estimate PDFs.
ESTIMATES_DIR=

# Python is used only for PDF password encryption through pypdf.
PYTHON_BIN=python

# OCR tools used by Admin > Preimport document staging.
# ocrmypdf makes scanned PDFs searchable; tesseract reads image files.
OCRMYPDF_BIN=ocrmypdf
TESSERACT_BIN=tesseract
PDFTOTEXT_BIN=pdftotext
OCR_LANGUAGE=eng
OCR_TIMEOUT_MS=180000

# SMTP can be filled in later. When these are missing, final PDFs are saved
# locally and signing-link emails are skipped.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Edgewater Cabinet Store <emailserver@edgewaterhomestores.com>"
SMTP_TO=edgewatercabinetstore@gmail.com
SMTP_CONNECTION_TIMEOUT_MS=10000
SMTP_GREETING_TIMEOUT_MS=10000
SMTP_SOCKET_TIMEOUT_MS=15000

# Optional diagnostics only for older MySQL checks.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASS=
MYSQL_DATABASE=

# Optional PostgreSQL record storage. When set, the portal initializes tables
# on startup and mirrors live
# contract packets, estimate records, customers, suppliers, products,
# import runs, and contract autosave drafts into PostgreSQL. PDFs and
# uploaded/OCR documents remain server files.
DATABASE_URL=postgresql://customer_portal_user:CHANGE_THIS_TO_A_STRONG_PASSWORD@localhost:5432/customer_portal
